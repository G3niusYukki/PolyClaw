DATABASE_URL=sqlite:///./polyclaw.db
MARKET_SOURCE=polymarket
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com/markets
REQUEST_TIMEOUT_SECONDS=20

EXECUTION_MODE=paper
REQUIRE_APPROVAL=true
AUTO_EXECUTE=false
LIVE_TRADING_ENABLED=false
SHADOW_MODE_ENABLED=true
SHADOW_STAGE=0
REQUIRE_APPROVAL_GATE=true

MAX_POSITION_USD=50
MAX_TOTAL_EXPOSURE_USD=250
MIN_CONFIDENCE=0.62
MIN_EDGE_BPS=700
MAX_SPREAD_BPS=400
MIN_LIQUIDITY_USD=1000
MAX_MARKET_AGE_MINUTES=180
SCAN_LIMIT=20
MAX_DAILY_LOSS_USD=200
MAX_CONSECUTIVE_FAILURES=3

POLYGON_RPC_URL=https://polygon-rpc.com
CTF_CONTRACT_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
PRICE_BAND_PCT=2.0
DEFAULT_POLL_INTERVAL=5
DEFAULT_POLL_TIMEOUT=60

# LLM Integration (LLM_PROVIDER,, LLM_API_KEY, LLM_MODEL)
# Uncomment: LLM_PROVIDER, LLM_MODEL, LLM_API_KEY
